NEXT_PUBLIC_SUPABASE_URL=https://epremgahbzjnlpzaqdcj.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# (Removed) Engine DB: the blog system is consolidated onto the single
# marketing Supabase project above — autoblog_runs/_settings, pillar_topics and
# blog_posts all live there, served by SUPABASE_SERVICE_ROLE_KEY.

# MK8: Content gate JWT signing
GATE_JWT_SECRET=your-gate-jwt-secret-here

# MK8: GA4 server-side proxy
GA4_MEASUREMENT_ID=your-ga4-measurement-id
GA4_API_SECRET=your-ga4-api-secret

# MK8: AI content brief generator
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# MK8: Cyberimpact email marketing
CYBERIMPACT_API_KEY=your-cyberimpact-api-key-here
CYBERIMPACT_PSIB_GROUP_ID=your-psib-group-id-here
CYBERIMPACT_GEO_GROUP_ID=your-geo-group-id-here

# MK8: Anthropic AI (overrides for content brief generator)
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_API_VERSION=2023-06-01

# Cron job authentication
CRON_SECRET=your-cron-secret-here

# Log drain ingestion (/api/drains/vercel + /api/drains/supabase)
VERCEL_LOG_DRAIN_SECRET=your-vercel-drain-secret-here
SUPABASE_LOG_DRAIN_TOKEN=your-supabase-drain-bearer-token-here

# B2B-INTEL-001: B2B intelligence waterfall pipeline (/api/intel/*)
# Stage 1+2 — Google Places API (New): Text Search Pro + Place Details Pro
GOOGLE_PLACES_API_KEY=your-google-places-api-key-here
# Stage 3 — Google Custom Search JSON API (domain-targeted engine; falls back to
# GOOGLE_PLACES_API_KEY if unset). Engine (cx) must whitelist linkedin.com/in/,
# jobs.lever.co and boards.greenhouse.io (whole-web search is deprecated in 2026).
GOOGLE_CUSTOM_SEARCH_API_KEY=your-google-custom-search-api-key-here
GOOGLE_CUSTOM_SEARCH_ENGINE_ID=your-cse-cx-id-here
# Stage 4 — AI extraction. Gemini 2.5 Flash is primary; if GEMINI_API_KEY is
# unset the pipeline falls back to the existing ANTHROPIC_API_KEY above.
GEMINI_API_KEY=your-gemini-api-key-here
# Optional overrides:
# GEMINI_MODEL=gemini-2.5-flash
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
# USD_TO_CAD=1.37
# Scheduled sweep (/api/intel/cron) — comma-separated seed queries
INTEL_CRON_QUERIES=Software companies in Alberta,IT services in Ontario
INTEL_CRON_LIMIT=20
